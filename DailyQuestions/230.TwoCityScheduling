https://leetcode.com/problems/two-city-scheduling/ 19-03-26

class Solution {
    public int twoCitySchedCost(int[][] costs) {
        Arrays.sort(costs, (a,b) -> Integer.compare(b[1]-b[0], a[1]-a[0]));
        int cost=0;
        int n = costs.length;
        for(int i=0;i<n;i++){
            cost += (i>=n/2) ? costs[i][1] : costs[i][0];
        }
        return cost;
    }
}