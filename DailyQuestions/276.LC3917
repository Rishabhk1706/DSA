https://leetcode.com/problems/count-indices-with-opposite-parity/ 05-05-26

class Solution {
    public int[] countOppositeParity(int[] nums) {
        int n = nums.length;
        int[] ans = new int[n];
        int even=0;
        for(int i=n-1;i>=0;i--){
            if(nums[i]%2==0){
                ans[i] = n-i-1-even;
                even++;
            }
            else{
                ans[i] = even;
            }
        }
        return ans;
    }
}