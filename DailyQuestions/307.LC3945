https://leetcode.com/problems/digit-frequency-score/description/ 31-05-26

class Solution {
    public int digitFrequencyScore(int n) {
        int[] f = new int[10];
        while(n>0){
            f[n%10]++;
            n = n/10;
        }
        int sum=0;
        for(int i=0;i<10;i++){
            sum+=i*f[i];
        }
        return sum;
    }
}