https://leetcode.com/problems/minimum-cost-of-buying-candies-with-discount 01-06-26

class Solution {
    public int minimumCost(int[] cost) {
        Arrays.sort(cost);
        int sum=0;
        int k=0;
        for(int i=cost.length-1;i>=0;i--){
            k++;
            if(k==3){
                k=0;
            }
            else sum+=cost[i];
        }
        return sum;
    }
}