https://leetcode.com/problems/check-if-array-is-sorted-and-rotated 23-05-26

class Solution {
    public boolean check(int[] nums) {
        int c=0;
        int n=nums.length;
        for(int i=0;i<n;i++){
            if(nums[i]>nums[(i+1)%n]){
                c++;
            }
        }
        return c<=1;
    }
}