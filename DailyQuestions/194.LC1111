https://leetcode.com/problems/maximum-nesting-depth-of-two-valid-parentheses-strings 11-02-26

class Solution {
    public int[] maxDepthAfterSplit(String seq) {
        int cur=0;
        int[] ans = new int[seq.length()];
        for(int i=0;i<seq.length();i++){
            if(seq.charAt(i)=='('){
                ans[i] = cur%2;
                cur++;
            }
            else{
                cur--;
                ans[i] = cur%2;
            }
        }
        return ans;
    }
}