https://leetcode.com/problems/count-subarrays-with-majority-element-i/description 25-06-26

class Solution {
    public int countMajoritySubarrays(int[] nums, int target) {
        int n = nums.length;
        int ans=0;
        int cnt=0;
        for(int i=0;i<n;i++){
            for(int j=i;j<n;j++){
                if(nums[j]==target){
                    cnt++;
                }
                if(cnt>(j-i+1)/2) ans++;
            }
            cnt=0;
        }
        return ans;
    }
}