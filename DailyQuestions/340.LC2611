https://leetcode.com/problems/mice-and-cheese/ 03-07-26

class Solution {
    public int miceAndCheese(int[] a, int[] b, int k) {
        int n = a.length;
        int[] diff = new int[n];
        int res=0;
        for(int i=0;i<n;i++){
            diff[i] = a[i] - b[i];
            res += b[i];
        }
        Arrays.sort(diff);
        for(int i=0;i<k;i++){
            res+=
            diff[n-i-1];
        }
        return res;
    }
}