https://leetcode.com/problems/mirror-distance-of-an-integer 18-04-26

class Solution {
    public int mirrorDistance(int n) {
        int num = 0;
        int copy = n;
        while(copy>0){
            int d = copy%10;
            num = num*10 + d;
            copy = copy/10;
        }
        return Math.abs(num-n);
    }
}