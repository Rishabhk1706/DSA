https://leetcode.com/problems/maximum-subarray/description/ 02-07-26

class Solution {
    public int maxSubArray(int[] nums) {
        int maxi = Integer.MIN_VALUE;
        int n=nums.length;
        int sum=0;
        for(int r=0;r<n;r++){
            sum+=nums[r];
            maxi = Math.max(maxi,sum);
            if(sum<0){
                sum=0;
            }
        }
        return maxi;
    }
}