https://leetcode.com/problems/average-waiting-time/description 18-05-26

class Solution {
    public double averageWaitingTime(int[][] customers) {
        long sum=0;
        long last=customers[0][0];
        for(int[] t : customers){
            if(last<t[0]){
                last = t[0];
            }
            last+=t[1];
            sum+=(last-t[0]);
        }
        return (double) sum/customers.length;
    }
}