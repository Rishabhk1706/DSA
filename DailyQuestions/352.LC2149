https://leetcode.com/problems/rearrange-array-elements-by-sign/ 16-07-26

class Solution {
    public int[] rearrangeArray(int[] nums) {
        int n = nums.length;
        int pos=0;
        int neg=1;
        int[] res = new int[n];
        for(int i=0;i<n;i++){
            if(nums[i]<0){
                res[neg] = nums[i];
                neg+=2;
            }
            else{
                res[pos] = nums[i];
                pos+=2;
            }
        }
        return res;
    }
}