https://leetcode.com/problems/flip-square-submatrix-vertically/description 21-03-26

class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {
        for(int j=y;j<y+k;j++){
            int l = x;
            int r = x+k-1;
            while(l<r){
                int temp = grid[l][j];
                grid[l][j] = grid[r][j];
                grid[r][j] = temp;
                l++;
                r--;
            }
        }
        return grid;
    }
}