https://leetcode.com/problems/angle-between-hands-of-a-clock 18-06-26

class Solution {
    public double angleClock(int hour, int minutes) {
        hour = hour%12;
        double hr = (double) hour*30;
        hr += (double) minutes*0.5;
        double min = (double) (minutes*6);
        double a = (360.0 - Math.max(min,hr)) + Math.min(min,hr);
        return Math.min(a, Math.abs(hr-min));
    }
}