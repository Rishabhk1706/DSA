https://leetcode.com/problems/left-and-right-sum-differences/description 06-06-26

class Solution {
    public int[] leftRightDifference(int[] nums) {
        int n = nums.length;
        int[] left = new int[n];
        for(int i=1;i<n;i++){
            left[i] = left[i-1] + nums[i-1];
        }
        int[] right = new int[n];
        for(int i=n-2;i>=0;i--){
            right[i] = right[i+1] + nums[i+1];
        }
        int[] ans = new int[n];
        for(int i=0;i<n;i++){
            ans[i] = Math.abs(left[i] - right[i]);
        }
        return ans;
    }
}